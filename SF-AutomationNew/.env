# ─────────────────────────────────────────────────────────────────────────────
# Salesforce Playwright Automation – Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Do not move it to the git since it contain credentials
# ─────────────────────────────────────────────────────────────────────────────


# ── Option A: Username & Password login ────
# The standard Salesforce login page URL (Sandbox)
SF_LOGIN_URL=

# Your Salesforce username (e.g.  john.doe@mycompany.com.sandbox)
SF_USERNAME=



# Your Salesforce password
SF_PASSWORD=

## Sequel90Going95Bloating9^Mantra9

# ── Option B: Session ID URL (uses the frontdoor.jsp?sid=) ───────
# If you already have a valid Salesforce session you can paste the full URL
# here (copy it from your browser address bar while logged in).
# When this is set the username/password fields above are ignored.
# Leave blank to use Option A.
SF_SESSION_URL=

# ── Salesforce Home URL (optional) ──────
# After login the test navigates here.  If left blank the test will try to
# build the URL automatically from the org you logged into.
# Example: https://myorg.sandbox.lightning.force.com/lightning/page/home
SF_HOME_URL=
